# Stripe Integration
# Get these values from your Stripe Dashboard: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs for your subscription products (create products in Stripe Dashboard)
STRIPE_MONTHLY_PRICE_ID=price_monthly_...
STRIPE_YEARLY_PRICE_ID=price_yearly_...
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_monthly_...
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_yearly_...
# Promotion code IDs (create promotion codes in Stripe Dashboard)
STRIPE_PROMO_CODE_SPARKY14=promo_...
STRIPE_PROMO_CODE_BETAFRIEND=promo_...

# Supabase (already set)
NEXT_PUBLIC_SUPABASE_URL=https://...
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...
CREDENTIAL_ENCRYPTION_KEY=...

# Optional: App URL for redirects (defaults to localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ollama (local zero‑cost AI inference)
OLLAMA_ENDPOINT=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M